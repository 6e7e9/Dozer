
<!DOCTYPE html>
<html lang="ku" dir="rtl" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Security-Policy" content="default-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tailwindcss.com https://placehold.co https://*.placehold.co; img-src 'self' data: https:; connect-src 'self';">
    <meta name="referrer" content="no-referrer">
    <title>Dozer - دۆزەر | پلاتفۆرمی زانیاری</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['Segoe UI', 'system-ui', 'sans-serif'] },
                    colors: {
                        brand: { 50: '#eff6ff', 100: '#dbeafe', 500: '#3b82f6', 600: '#2563eb', 700: '#1d4ed8' },
                        gold: { 400: '#d4a017', 500: '#b8860b', 600: '#9a7209' },
                    },
                }
            }
        }
    </script>
    <style>
        :root {
            --bg-light: #f8fafc; --card-light: #ffffff; --text-light: #1e293b; --text-secondary-light: #64748b; --border-light: #e2e8f0;
            --bg-dark: #0f172a; --card-dark: #1e293b; --text-dark: #f1f5f9; --text-secondary-dark: #94a3b8; --border-dark: #334155;
        }
        * { box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            transition: background-color 0.3s ease, color 0.3s ease;
            min-height: 100vh; line-height: 1.6;
            background-color: var(--bg-light); color: var(--text-light);
        }
        .dark body { background-color: var(--bg-dark); color: var(--text-dark); }
        body, .card-themed, .header-themed, .modal-themed {
            transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
        }

        .blurred-content { filter: blur(7px); user-select: none; pointer-events: none; transition: filter 0.5s ease; }
        .blurred-content.revealed { filter: blur(0); user-select: auto; pointer-events: auto; }
        .blur-overlay {
            position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
            z-index: 10; background: rgba(148,163,184,0.2); backdrop-filter: blur(2px); border-radius: 16px;
            transition: all 0.4s ease;
        }
        .blur-overlay.hidden-overlay { opacity: 0; pointer-events: none; }

        .listing-card {
            transition: transform 0.25s ease, box-shadow 0.25s ease; border-radius: 20px; overflow: hidden;
            cursor: pointer; border: 1px solid var(--border-light); background: var(--card-light);
        }
        .dark .listing-card { border-color: var(--border-dark); background: var(--card-dark); }
        .listing-card:hover { transform: translateY(-6px); box-shadow: 0 20px 40px rgba(0,0,0,0.1); }

        .modal-backdrop {
            position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 200;
            display: flex; align-items: center; justify-content: center; animation: fadeIn 0.2s ease;
        }
        .modal-container {
            background: #fff; border-radius: 24px; padding: 2rem; max-width: 480px; width: 92%;
            max-height: 85vh; overflow-y: auto; position: relative; animation: slideUp 0.3s ease;
            box-shadow: 0 25px 60px rgba(0,0,0,0.25);
        }
        .dark .modal-container { background: #1e293b; color: #f1f5f9; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes slideUp { from { transform: translateY(35px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

        .btn-primary {
            background: #2563eb; color: #fff; padding: 0.8rem 1.8rem; border-radius: 14px;
            font-weight: 600; border: none; cursor: pointer; transition: all 0.2s ease; font-size: 1rem;
            display: inline-flex; align-items: center; gap: 0.5rem;
        }
        .btn-primary:hover { background: #1d4ed8; transform: scale(1.02); }
        .btn-gold {
            background: linear-gradient(135deg, #b8860b, #d4a017); color: #fff;
            padding: 0.8rem 1.8rem; border-radius: 14px; font-weight: 700; border: none;
            cursor: pointer; transition: all 0.2s ease; font-size: 1rem; display: inline-flex; align-items: center; gap: 0.5rem;
        }
        .btn-gold:hover { transform: scale(1.04); box-shadow: 0 10px 25px rgba(184,134,11,0.45); }

        .input-field {
            width: 100%; padding: 0.85rem 1rem; border: 2px solid #e2e8f0; border-radius: 14px;
            font-size: 1rem; transition: all 0.2s ease; background: #fff; color: #1e293b;
        }
        .dark .input-field { background: #1e293b; border-color: #334155; color: #f1f5f9; }
        .input-field:focus { outline: none; border-color: #2563eb; box-shadow: 0 0 0 4px rgba(37,99,235,0.15); }

        .cat-badge {
            display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.35rem 1rem;
            border-radius: 20px; font-size: 0.8rem; font-weight: 600; background: #dbeafe; color: #1d4ed8;
        }
        .dark .cat-badge { background: #1e3a5f; color: #93c5fd; }

        .listings-grid {
            display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; padding: 0.5rem 0;
        }
        @media (max-width: 640px) { .listings-grid { grid-template-columns: 1fr; } }

        .toast {
            position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%); padding: 0.9rem 2rem;
            border-radius: 14px; color: #fff; font-weight: 600; z-index: 300; animation: slideUp 0.3s ease;
            box-shadow: 0 12px 30px rgba(0,0,0,0.2);
        }
        .toast-success { background: #16a34a; } .toast-error { background: #dc2626; }

        .filter-dropdown {
            position: absolute; top: 60px; right: 0; background: #fff; border-radius: 16px;
            box-shadow: 0 12px 40px rgba(0,0,0,0.15); padding: 1rem; min-width: 180px; z-index: 60;
            border: 1px solid #e2e8f0;
        }
        .dark .filter-dropdown { background: #1e293b; border-color: #334155; }

        .admin-table th { background: #f1f5f9; font-weight: 700; position: sticky; top: 0; }
        .dark .admin-table th { background: #1e293b; }
        .admin-table td, .admin-table th { padding: 0.7rem 0.8rem; border-bottom: 1px solid #e2e8f0; white-space: nowrap; font-size: 0.85rem; }
        .dark .admin-table td, .dark .admin-table th { border-bottom-color: #334155; }

        .copy-link-btn {
            background: none; border: none; cursor: pointer; color: #2563eb; padding: 4px; border-radius: 8px;
            display: inline-flex; align-items: center; transition: background 0.2s;
        }
        .copy-link-btn:hover { background: #eff6ff; }
        .dark .copy-link-btn:hover { background: #1e3a5f; }
    </style>
</head>
<body class="bg-[#f8fafc] text-[#1e293b] dark:bg-[#0f172a] dark:text-[#f1f5f9]">

<!-- ==================== HEADER ==================== -->
<header class="sticky top-0 z-50 bg-white/90 dark:bg-slate-900/90 backdrop-blur-lg border-b border-gray-200 dark:border-gray-700 shadow-sm header-themed">
    <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
        <!-- Logo (5 taps for admin) -->
        <div id="logo-area" class="flex items-center gap-2 cursor-pointer select-none" onclick="handleLogoTap(event)">
            <div class="w-10 h-10 bg-gradient-to-br from-blue-600 to-indigo-700 rounded-xl flex items-center justify-center">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><rect x="4" y="3" width="16" height="18" rx="3" stroke="white" stroke-width="3"/><path d="M8 8L16 8M8 12L14 12M8 16L16 16" stroke="white" stroke-width="2.5" stroke-linecap="round"/></svg>
            </div>
            <span class="text-xl font-bold text-gray-800 dark:text-white tracking-tight">Dozer</span>
        </div>

        <!-- Right controls -->
        <div class="flex items-center gap-2 relative">
            <!-- Filter Icon -->
            <button id="filter-icon-btn" class="p-2 rounded-xl bg-gray-100 dark:bg-slate-700 hover:bg-gray-200 dark:hover:bg-slate-600 transition-colors border-none cursor-pointer relative" onclick="toggleFilterDropdown()" aria-label="Filter">
                <svg class="w-5 h-5 text-gray-600 dark:text-gray-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
            </button>
            <!-- Filter Dropdown -->
            <div id="filter-dropdown-menu" class="filter-dropdown hidden" style="right: 0;">
                <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 mb-2 px-2" data-i18n="filter_title">پۆلێن</p>
                <div class="space-y-1">
                    <button class="w-full text-left px-3 py-2 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors font-medium text-gray-700 dark:text-gray-200" data-cat="all" onclick="selectFilterCategory('all')" data-i18n="filter_all">هەموو</button>
                    <button class="w-full text-left px-3 py-2 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors font-medium text-gray-700 dark:text-gray-200" data-cat="cars" onclick="selectFilterCategory('cars')" data-i18n="filter_cars">ئۆتۆمبێل</button>
                    <button class="w-full text-left px-3 py-2 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors font-medium text-gray-700 dark:text-gray-200" data-cat="phones" onclick="selectFilterCategory('phones')" data-i18n="filter_phones">مۆبایل</button>
                    <button class="w-full text-left px-3 py-2 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors font-medium text-gray-700 dark:text-gray-200" data-cat="realestate" onclick="selectFilterCategory('realestate')" data-i18n="filter_realestate">خانووبەرە</button>
                    <button class="w-full text-left px-3 py-2 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors font-medium text-gray-700 dark:text-gray-200" data-cat="electronics" onclick="selectFilterCategory('electronics')" data-i18n="filter_electronics">ئەلیکترۆنیات</button>
                    <button class="w-full text-left px-3 py-2 rounded-lg text-sm hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors font-medium text-gray-700 dark:text-gray-200" data-cat="other" onclick="selectFilterCategory('other')" data-i18n="filter_other">هی تر</button>
                </div>
            </div>

            <!-- Dark Mode Toggle -->
            <button class="p-2 rounded-xl bg-gray-100 dark:bg-slate-700 hover:bg-gray-200 dark:hover:bg-slate-600 transition-colors cursor-pointer border-none" onclick="toggleDarkMode()" aria-label="Toggle dark mode">
                <svg id="sun-icon" class="w-5 h-5 hidden dark:block text-yellow-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
                <svg id="moon-icon" class="w-5 h-5 block dark:hidden text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
            </button>

            <!-- Language Switcher -->
            <select id="lang-switcher" class="input-field py-2 px-3 w-auto text-sm cursor-pointer rounded-xl border-2 bg-white dark:bg-slate-800" aria-label="Select language">
                <option value="ku">کوردی</option>
                <option value="ar">العربية</option>
                <option value="en">English</option>
            </select>
        </div>
    </div>
</header>

<!-- ==================== MAIN CONTENT ==================== -->
<main id="app-content" class="max-w-7xl mx-auto min-h-[70vh] px-4 py-6 page-content"></main>

<!-- ==================== FOOTER ==================== -->
<footer class="border-t border-gray-200 dark:border-gray-700 py-5 text-center text-sm text-gray-500 dark:text-gray-400">
    <span data-i18n="footer_text">&copy; 2026 Dozer Platform. هەموو مافێک پارێزراوە.</span>
</footer>

<!-- ==================== UNLOCK MODAL ==================== -->
<div id="unlock-modal" class="modal-backdrop" style="display:none;" role="dialog" aria-modal="true">
    <div class="modal-container modal-themed relative">
        <button onclick="closeModal()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 text-2xl leading-none cursor-pointer bg-transparent border-none z-10" aria-label="Close">&times;</button>
        <h2 class="text-xl font-bold mb-3" data-i18n="modal_title">کردنەوەی زانیاری خاوەن</h2>
        <p class="text-gray-600 dark:text-gray-300 text-sm mb-4" data-i18n="modal_description">بۆ وەرگرتنی زانیاری خاوەن، تکایە لە ڕێگەی واتسئەپەوە پەیوەندی بکە.</p>
        <div class="bg-green-50 dark:bg-green-900/30 border-2 border-green-200 dark:border-green-700 rounded-2xl p-5 mb-4 text-center">
            <svg class="w-10 h-10 mx-auto mb-2 text-green-500" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <p class="font-bold text-green-800 dark:text-green-200 text-lg">WhatsApp</p>
            <p class="text-green-700 dark:text-green-300 text-sm font-mono mt-1" dir="ltr">+964 770 543 5169</p>
            <a href="https://wa.me/9647705435169" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-3 bg-green-500 hover:bg-green-600 text-white font-semibold py-2 px-5 rounded-xl transition-colors text-sm no-underline">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                <span data-i18n="open_whatsapp">کردنەوەی واتسئەپ</span>
            </a>
        </div>
        <div class="bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-700 rounded-2xl p-4 mb-4">
            <p class="text-sm text-blue-800 dark:text-blue-200" data-i18n="modal_instructions">ڕێنمایی: لە ڕێگەی واتسئەپەوە پەیوەندی بە بەڕێوەبەرەوە بکە. دوای پارەدان، بەڕێوەبەر کۆدی چالاککردنت بۆ دەنێرێت.</p>
        </div>
        <label class="block text-sm font-semibold mb-1 dark:text-gray-200" data-i18n="enter_code">کۆدی چالاککردن بنووسە:</label>
        <input type="text" id="activation-code-input" class="input-field mb-3" placeholder="DZ-XXXX-X" autocomplete="off" maxlength="20">
        <button id="verify-code-btn" class="btn-gold w-full justify-center" data-i18n="verify_unlock">پشتڕاستکردنەوە و کردنەوە</button>
        <p id="modal-error" class="text-red-500 text-sm mt-2 hidden text-center"></p>
        <div id="modal-loading" class="text-center mt-3 hidden"><span class="inline-block w-6 h-6 border-2 border-gray-300 border-t-blue-600 rounded-full animate-spin"></span></div>
    </div>
</div>

<!-- Toast container -->
<div id="toast-container"></div>

<script>
(function() {
    // ==================== CONFIG (UPDATED CREDENTIALS) ====================
    const ADMIN_USERNAME = 'Rebwar1989';
    const ADMIN_PASSWORD = 'Rebwar456@';   // Changed from Rashid@456
    const WHATSAPP_NUMBER = '+964 770 543 5169';
    const DEFAULT_LANG = 'ku';

    // ==================== STATE ====================
    let currentLang = localStorage.getItem('dozer_lang_v5') || DEFAULT_LANG;
    let isDarkMode = localStorage.getItem('dozer_dark_v5') === 'true';
    let isAdminLoggedIn = sessionStorage.getItem('dozer_admin_v5') === 'true';
    let currentCategoryFilter = 'all';
    let logoTapCount = 0;
    let logoTapTimer = null;

    // ==================== i18n (includes admin form labels & new copy link) ====================
    const translations = {
        ku: {
            tagline: 'پلاتفۆرمی زانیاری', footer_text: '© 2026 Dozer Platform.', homepage_title: 'هەموو لیستینگەکان',
            no_listings: 'هیچ لیستینگێک بەردەست نییە.', view_details: 'بینینی وردەکاری', category_label: 'پۆلێن',
            base_price: 'نرخ', unlock_fee_label: 'کرێی کردنەوە', detail_page_title: 'وردەکاری', back_to_home: 'گەڕانەوە',
            general_description: 'شیکردنەوە', hidden_section_title: 'زانیاری خاوەن (شاراوە)',
            unlock_button: 'کردنەوەی زانیاری', unlocked_section: 'زانیاری خاوەن (کراوە)',
            owner_name: 'ناوی خاوەن', owner_phone: 'ژمارە', exact_location: 'شوێن', admin_notes: 'تێبینی',
            modal_title: 'کردنەوەی زانیاری', modal_description: 'بۆ زانیاری خاوەن لە واتسئەپ پەیوەندی بکە.',
            modal_instructions: 'ڕێنمایی: دوای پارەدان کۆدی چالاککردن وەردەگریت.',
            enter_code: 'کۆدی چالاککردن:', verify_unlock: 'پشتڕاستکردنەوە', invalid_code: 'کۆد هەڵەیە یان بەکارهاتووە.',
            code_verified: 'کۆد دروستە! زانیاری پیشان دەدرێت.', open_whatsapp: 'کردنەوەی واتسئەپ',
            admin_login: 'چوونەژوورەوە', admin_username: 'ناوی بەکارهێنەر', admin_password: 'وشەی نهێنی',
            admin_login_btn: 'چوونەژوورەوە', admin_logout: 'چوونەدەرەوە', admin_add_listing: 'زیادکردنی لیستینگ',
            admin_code_generator: 'دروستکردنی کۆد', admin_listing_id_label: 'ID', admin_generate_btn: 'دروستکردن',
            admin_generated_code: 'کۆدی دروستکراو:', admin_copy_code: 'کۆپی', admin_copied: 'کۆپی کرا!',
            admin_save_listing: 'پاشەکەوتکردن', admin_listing_saved: 'لیستینگ پاشەکەوت کرا. کۆد:',
            admin_login_error: 'زانیاری هەڵەیە.', filter_title: 'پۆلێنەکان', filter_all: 'هەموو', filter_cars: 'ئۆتۆمبێل',
            filter_phones: 'مۆبایل', filter_realestate: 'خانووبەرە', filter_electronics: 'ئەلیکترۆنیات', filter_other: 'هی تر',
            share_link: 'هاوبەشکردنی بەستەر', link_copied: 'بەستەر کۆپی کرا!',
            copy_listing_link: 'کۆپی بەستەری ڕێکلام', listing_link_copied: 'بەستەری ڕێکلام کۆپی کرا',
            form_title_ku: 'ناونیشان (کوردی)', form_title_ar: 'ناونیشان (عەرەبی)', form_title_en: 'ناونیشان (ئینگلیزی)',
            form_desc_ku: 'شیکردنەوە (کوردی)', form_desc_ar: 'شیکردنەوە (عەرەبی)', form_desc_en: 'شیکردنەوە (ئینگلیزی)',
            form_category: 'پۆلێن', form_image_url: 'لینکی وێنە', form_base_price: 'نرخی بنەڕەتی',
            form_unlock_fee: 'کرێی کردنەوە', form_owner_name: 'ناوی خاوەن (شاراوە)', form_owner_phone: 'ژمارەی خاوەن (شاراوە)',
            form_location: 'شوێن (شاراوە)', form_notes: 'تێبینی (شاراوە)',
            add_listing_guide: 'تکایە پۆلێن و جۆری کاڵا دیاری بکە و زانیارییەکان پڕ بکەرەوە. دوای پاشەکەوتکردن، کۆدی چالاککردن بە شێوەیەکی ڕاندۆم دروست دەکرێت.',
            categories: { cars:'ئۆتۆمبێل', phones:'مۆبایل', realestate:'خانووبەرە', electronics:'ئەلیکترۆنیات', other:'هی تر' }
        },
        ar: {
            tagline: 'منصة المعلومات', footer_text: '© 2026 Dozer.', homepage_title: 'جميع القوائم', no_listings: 'لا توجد قوائم.',
            view_details: 'عرض التفاصيل', category_label: 'الفئة', base_price: 'السعر', unlock_fee_label: 'رسوم الفتح',
