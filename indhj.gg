            admin_login_btn: 'دخول', admin_logout: 'خروج', admin_add_listing: 'إضافة', admin_code_generator: 'إنشاء رمز',
            admin_listing_id_label: 'ID', admin_generate_btn: 'إنشاء', admin_generated_code: 'الرمز:', admin_copy_code: 'نسخ',
            admin_copied: 'تم النسخ!', admin_save_listing: 'حفظ', admin_listing_saved: 'تم الحفظ. الرمز:',
            admin_login_error: 'بيانات خاطئة.', filter_title: 'الفئات', filter_all: 'الكل', filter_cars: 'سيارات',
            filter_phones: 'هواتف', filter_realestate: 'عقارات', filter_electronics: 'إلكترونيات', filter_other: 'أخرى',
            share_link: 'مشاركة الرابط', link_copied: 'تم نسخ الرابط!',
            copy_listing_link: 'نسخ رابط الإعلان', listing_link_copied: 'تم نسخ رابط الإعلان',
            form_title_ku: 'العنوان (كردي)', form_title_ar: 'العنوان (عربي)', form_title_en: 'العنوان (إنجليزي)',
            form_desc_ku: 'الوصف (كردي)', form_desc_ar: 'الوصف (عربي)', form_desc_en: 'الوصف (إنجليزي)',
            form_category: 'الفئة', form_image_url: 'رابط الصورة', form_base_price: 'السعر الأساسي',
            form_unlock_fee: 'رسوم الفتح', form_owner_name: 'اسم المالك (مخفي)', form_owner_phone: 'رقم المالك (مخفي)',
            form_location: 'الموقع (مخفي)', form_notes: 'ملاحظات (مخفية)',
            add_listing_guide: 'يرجى تحديد الفئة ونوع المنتج وملء البيانات. بعد الحفظ، سيتم إنشاء رمز التفعيل بشكل عشوائي.',
            categories: { cars:'سيارات', phones:'هواتف', realestate:'عقارات', electronics:'إلكترونيات', other:'أخرى' }
        },
        en: {
            tagline: 'Information Platform', footer_text: '© 2026 Dozer.', homepage_title: 'All Listings', no_listings: 'No listings.',
            view_details: 'View Details', category_label: 'Category', base_price: 'Price', unlock_fee_label: 'Unlock Fee',
            detail_page_title: 'Details', back_to_home: 'Back', general_description: 'Description',
            hidden_section_title: 'Owner Info (Hidden)', unlock_button: 'Unlock Info', unlocked_section: 'Owner Info (Unlocked)',
            owner_name: 'Owner Name', owner_phone: 'Phone', exact_location: 'Location', admin_notes: 'Notes',
            modal_title: 'Unlock Info', modal_description: 'Contact via WhatsApp.', modal_instructions: 'After payment you will receive a code.',
            enter_code: 'Activation Code:', verify_unlock: 'Verify', invalid_code: 'Invalid code.', code_verified: 'Verified!',
            open_whatsapp: 'Open WhatsApp', admin_login: 'Admin Login', admin_username: 'Username', admin_password: 'Password',
            admin_login_btn: 'Login', admin_logout: 'Logout', admin_add_listing: 'Add Listing', admin_code_generator: 'Generate Code',
            admin_listing_id_label: 'ID', admin_generate_btn: 'Generate', admin_generated_code: 'Code:', admin_copy_code: 'Copy',
            admin_copied: 'Copied!', admin_save_listing: 'Save', admin_listing_saved: 'Saved. Code:',
            admin_login_error: 'Invalid credentials.', filter_title: 'Categories', filter_all: 'All', filter_cars: 'Cars',
            filter_phones: 'Phones', filter_realestate: 'Real Estate', filter_electronics: 'Electronics', filter_other: 'Other',
            share_link: 'Share Link', link_copied: 'Link copied!',
            copy_listing_link: 'Copy ad link', listing_link_copied: 'Ad link copied',
            form_title_ku: 'Title (Kurdish)', form_title_ar: 'Title (Arabic)', form_title_en: 'Title (English)',
            form_desc_ku: 'Description (Kurdish)', form_desc_ar: 'Description (Arabic)', form_desc_en: 'Description (English)',
            form_category: 'Category', form_image_url: 'Image URL', form_base_price: 'Base Price',
            form_unlock_fee: 'Unlock Fee', form_owner_name: 'Owner Name (Hidden)', form_owner_phone: 'Owner Phone (Hidden)',
            form_location: 'Location (Hidden)', form_notes: 'Notes (Hidden)',
            add_listing_guide: 'Please choose category and product type then fill in the details. After saving, a random activation code will be generated.',
            categories: { cars:'Cars', phones:'Phones', realestate:'Real Estate', electronics:'Electronics', other:'Other' }
        }
    };

    function t(key) { return (translations[currentLang] || translations['ku'])[key] || key; }
    function tCat(key) { return (translations[currentLang]?.categories || translations['ku'].categories)[key] || key; }

    // ==================== DATABASE ====================
    function getListings() { try { return JSON.parse(localStorage.getItem('dozer_listings_v5')) || []; } catch(e) { return []; } }
    function saveListings(l) { localStorage.setItem('dozer_listings_v5', JSON.stringify(l)); }
    function getCodes() { try { return JSON.parse(localStorage.getItem('dozer_codes_v5')) || []; } catch(e) { return []; } }
    function saveCodes(c) { localStorage.setItem('dozer_codes_v5', JSON.stringify(c)); }
    function nextListingId() { const l = getListings(); return l.length ? Math.max(...l.map(x=>x.id))+1 : 1; }
    function nextCodeId() { const c = getCodes(); return c.length ? Math.max(...c.map(x=>x.code_id))+1 : 1; }
    function genUniqueCode() {
        const chars='ABCDEFGHJKLMNPQRSTUVWXYZ23456789'; let c='DZ-'; for(let i=0;i<4;i++) c+=chars[Math.floor(Math.random()*chars.length)]; c+='-'+chars[Math.floor(Math.random()*chars.length)];
        if(getCodes().some(x=>x.code_string===c)) return genUniqueCode(); return c;
    }

    // ==================== DARK MODE ====================
    function applyDarkMode() { document.documentElement.classList.toggle('dark', isDarkMode); localStorage.setItem('dozer_dark_v5', isDarkMode); }
    function toggleDarkMode() { isDarkMode = !isDarkMode; applyDarkMode(); }

    // ==================== ROUTER ====================
    function navigateTo(route) { window.location.hash = route; }
    function getRoute() { return window.location.hash.slice(1) || '/'; }
    function parseRoute(r) {
        if(r==='/'||r==='') return {page:'home'}; if(r.startsWith('/item/')) { const id=parseInt(r.split('/item/')[1]); return {page:'item',id:isNaN(id)?null:id}; }
        if(r==='/admin') return {page:'admin'}; return {page:'home'};
    }

    // ==================== FILTER ====================
    function toggleFilterDropdown() { document.getElementById('filter-dropdown-menu').classList.toggle('hidden'); }
    function selectFilterCategory(cat) { currentCategoryFilter = cat; document.getElementById('filter-dropdown-menu').classList.add('hidden'); renderApp(); }
    document.addEventListener('click', (e) => { if(!e.target.closest('#filter-icon-btn') && !e.target.closest('#filter-dropdown-menu')) document.getElementById('filter-dropdown-menu').classList.add('hidden'); });

    // ==================== LOGO TAP FOR ADMIN ====================
    function handleLogoTap(e) {
        logoTapCount++;
        if(logoTapTimer) clearTimeout(logoTapTimer);
        if(logoTapCount >= 5) { logoTapCount = 0; navigateTo('/admin'); showToast('🔐 بەڕێوەبەر', 'success'); }
        else { logoTapTimer = setTimeout(() => { logoTapCount = 0; }, 800); }
    }
    window.handleLogoTap = handleLogoTap;

    // ==================== RENDER ====================
    function renderApp() {
        const route = getRoute(); const parsed = parseRoute(route);
        const content = document.getElementById('app-content');
        if(parsed.page==='home') renderHome(content);
        else if(parsed.page==='item' && parsed.id) renderDetail(content, parsed.id);
        else if(parsed.page==='admin') renderAdmin(content);
        else renderHome(content);
        updateI18n(); updateDirection();
    }

    function updateI18n() {
        document.querySelectorAll('[data-i18n]').forEach(el=>{ if(el.tagName!=='INPUT'&&el.tagName!=='TEXTAREA') el.textContent=t(el.getAttribute('data-i18n')); });
        document.title = `Dozer - ${t('tagline')}`;
    }
    function updateDirection() {
        const rtl = currentLang==='ku'||currentLang==='ar'; document.documentElement.dir=rtl?'rtl':'ltr';
        document.documentElement.lang=currentLang; document.getElementById('lang-switcher').value=currentLang;
    }

    function renderHome(container) {
        let listings = getListings();
        if(currentCategoryFilter!=='all') listings = listings.filter(l=>l.category===currentCategoryFilter);
        let cards='';
        if(listings.length===0) cards=`<div class="col-span-full text-center py-20"><p class="text-gray-400">${t('no_listings')}</p></div>`;
        else listings.forEach(l=>{
            const title = (l.title&&l.title[currentLang])||l.title['ku']||'';
            cards+=`<div class="listing-card" onclick="navigateTo('/item/${l.id}')"><div class="aspect-[4/3] bg-gray-100 dark:bg-gray-700"><img src="${l.main_image_url||'https://placehold.co/600x400/cbd5e1/64748b'}" class="w-full h-full object-cover" onerror="this.src='https://placehold.co/600x400/cbd5e1/64748b'"></div><div class="p-4"><span class="cat-badge">${tCat(l.category)}</span><h3 class="text-lg font-bold mt-2 text-gray-800 dark:text-white line-clamp-2">${title}</h3><div class="flex justify-between mt-3"><span class="text-blue-600 dark:text-blue-400 font-bold">${l.base_price}</span><span class="text-amber-600 dark:text-amber-400 text-sm">${l.unlock_fee}</span></div><button class="btn-primary w-full mt-3" onclick="event.stopPropagation();navigateTo('/item/${l.id}')">${t('view_details')}</button></div></div>`;
        });
        container.innerHTML=`<div><h1 class="text-2xl font-bold mb-4">${t('homepage_title')}</h1><div class="listings-grid">${cards}</div></div>`;
    }

    function renderDetail(container, id) {
        const listing = getListings().find(l=>l.id===id);
        if(!listing) { container.innerHTML=`<div class="text-center py-20"><p>${t('no_listings')}</p></div>`; return; }
        const unlocked = sessionStorage.getItem('unlock_'+id)==='true';
        container.innerHTML=`
        <div class="max-w-3xl mx-auto"><button class="text-blue-600 mb-4 flex items-center gap-1" onclick="navigateTo('/')">← ${t('back_to_home')}</button>
        <div class="flex items-center gap-3 mb-2"><h1 class="text-2xl font-bold">${(listing.title&&listing.title[currentLang])||listing.title['ku']}</h1><span class="cat-badge">${tCat(listing.category)}</span></div>
        <img src="${listing.main_image_url||'https://placehold.co/800x450'}" class="rounded-2xl w-full aspect-[16/9] object-cover my-4">
        <div class="flex gap-2 mb-3"><button class="btn-primary text-sm" onclick="shareListing(${id})"><svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8M16 6l-4-4-4 4M12 2v13"/></svg> ${t('share_link')}</button></div>
        <div class="bg-white dark:bg-slate-800 rounded-2xl p-5 mb-4"><h3 class="font-semibold mb-2">${t('general_description')}</h3><p>${(listing.general_description&&listing.general_description[currentLang])||listing.general_description['ku']}</p></div>
        <div class="flex gap-4 mb-4"><div class="bg-blue-50 dark:bg-blue-900/30 rounded-xl p-4 flex-1"><span>${t('base_price')}</span><p class="text-2xl font-bold">${listing.base_price}</p></div><div class="bg-amber-50 dark:bg-amber-900/30 rounded-xl p-4 flex-1"><span>${t('unlock_fee_label')}</span><p class="text-2xl font-bold">${listing.unlock_fee}</p></div></div>
        <div class="relative bg-white dark:bg-slate-800 rounded-2xl p-5 border" id="premium-box"><h3 class="font-semibold mb-3">${unlocked?t('unlocked_section'):t('hidden_section_title')}</h3><div class="blurred-content ${unlocked?'revealed':''}" id="premium-content"><p><strong>${t('owner_name')}:</strong> <span>${listing.hidden_premium_info?.owner_name||'---'}</span></p><p><strong>${t('owner_phone')}:</strong> <span class="text-blue-600 font-mono">${listing.hidden_premium_info?.owner_phone||'---'}</span></p><p><strong>${t('exact_location')}:</strong> <span>${listing.hidden_premium_info?.exact_location||'---'}</span></p></div><div class="blur-overlay ${unlocked?'hidden-overlay':''}">${unlocked?'':`<button class="btn-gold" onclick="openUnlockModal(${id})">${t('unlock_button')}</button>`}</div></div></div>`;
    }

    function shareListing(id) {
        const url = window.location.origin + window.location.pathname + '#/item/' + id;
        navigator.clipboard.writeText(url).then(()=>showToast(t('link_copied'),'success')).catch(()=>showToast('Copy failed','error'));
    }

    // ==================== ADMIN ====================
    function renderAdmin(container) {
        if(!isAdminLoggedIn) {
            container.innerHTML=`
            <div class="max-w-md mx-auto py-12"><div class="bg-white dark:bg-slate-800 rounded-2xl p-8 shadow">
            <h2 class="text-xl font-bold mb-4 text-center">${t('admin_login')}</h2>
            <label class="block text-sm font-semibold mb-1">${t('admin_username')}</label><input type="text" id="admin-user" class="input-field mb-3" autocomplete="off" placeholder="Username">
            <label class="block text-sm font-semibold mb-1">${t('admin_password')}</label><input type="password" id="admin-pass" class="input-field mb-4" placeholder="Password">
            <button class="btn-primary w-full" onclick="handleAdminLogin()">${t('admin_login_btn')}</button>
            <p id="admin-error" class="text-red-500 text-sm mt-2 hidden">${t('admin_login_error')}</p></div></div>`;
        } else {
            const listings=getListings(), codes=getCodes();
            container.innerHTML=`
            <div class="flex flex-col lg:flex-row gap-6"><div class="lg:w-56"><div class="bg-slate-800 dark:bg-slate-900 rounded-2xl p-5 sticky top-24 text-white">
            <h2 class="text-lg font-bold mb-4">🔐 ${t('admin_login')}</h2>
            <a href="#add" onclick="scrollToSection(event,'add-section')" class="block py-2 px-3 rounded-lg hover:bg-slate-700">${t('admin_add_listing')}</a>
            <a href="#code" onclick="scrollToSection(event,'code-section')" class="block py-2 px-3 rounded-lg hover:bg-slate-700">${t('admin_code_generator')}</a>
            <a href="#table" onclick="scrollToSection(event,'table-section')" class="block py-2 px-3 rounded-lg hover:bg-slate-700">📋 لیستینگەکان</a>
            <hr class="my-3 border-gray-600"><button class="text-red-400 w-full text-left py-2 px-3 hover:bg-slate-700" onclick="handleAdminLogout()">${t('admin_logout')}</button></div></div>
            <div class="flex-1 space-y-6">
            <div id="add-section" class="bg-white dark:bg-slate-800 rounded-2xl p-6"><h3 class="text-xl font-bold mb-2">${t('admin_add_listing')}</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4" data-i18n="add_listing_guide">${t('add_listing_guide')}</p>
            <form id="add-form" onsubmit="handleAddListing(event)"><div class="grid grid-cols-1 md:grid-cols-3 gap-3">
            <div><label class="text-sm">${t('form_title_ku')}</label><input name="tku" class="input-field" required></div>
            <div><label class="text-sm">${t('form_title_ar')}</label><input name="tar" class="input-field" required></div>
            <div><label class="text-sm">${t('form_title_en')}</label><input name="ten" class="input-field" required></div></div>
            <div class="grid grid-cols-3 gap-3"><div><label>${t('form_desc_ku')}</label><textarea name="dku" class="input-field" rows="2" required></textarea></div>
            <div><label>${t('form_desc_ar')}</label><textarea name="dar" class="input-field" rows="2" required></textarea></div>
            <div><label>${t('form_desc_en')}</label><textarea name="den" class="input-field" rows="2" required></textarea></div></div>
            <div class="grid grid-cols-3 gap-3"><div><label>${t('form_category')}</label><select name="cat" class="input-field"><option value="cars">${tCat('cars')}</option><option value="phones">${tCat('phones')}</option><option value="realestate">${tCat('realestate')}</option><option value="electronics">${tCat('electronics')}</option><option value="other">${tCat('other')}</option></select></div>
            <div><label>${t('form_image_url')}</label><input name="img" class="input-field" placeholder="https://..."></div>
            <div><label>${t('form_base_price')}</label><input name="price" class="input-field" required></div></div>
            <div class="grid grid-cols-2 gap-3"><div><label>${t('form_unlock_fee')}</label><input name="fee" class="input-field" required></div>
            <div><label>${t('form_owner_name')}</label><input name="owner" class="input-field" required></div></div>
            <div class="grid grid-cols-2 gap-3"><div><label>${t('form_owner_phone')}</label><input name="phone" class="input-field" required></div>
            <div><label>${t('form_location')}</label><input name="loc" class="input-field" required></div></div>
            <div><label>${t('form_notes')}</label><textarea name="notes" class="input-field" rows="2"></textarea></div>
            <button type="submit" class="btn-primary w-full mt-3">${t('admin_save_listing')}</button></form>
            <div id="add-result" class="mt-3 hidden"><p class="text-green-600" id="add-msg"></p><p class="text-sm">کۆد: <strong id="add-code" class="text-xl font-mono"></strong></p></div></div>
            <div id="code-section" class="bg-white dark:bg-slate-800 rounded-2xl p-6"><h3 class="text-xl font-bold mb-4">${t('admin_code_generator')}</h3>
            <div class="flex gap-3 items-end"><div class="flex-1"><label>${t('admin_listing_id_label')}</label><input type="number" id="gen-id" class="input-field" min="1"></div>
            <button class="btn-gold" onclick="handleGenerateCode()">${t('admin_generate_btn')}</button></div>
            <div id="gen-display" class="mt-4 hidden"><p>${t('admin_generated_code')} <strong id="gen-code" class="text-xl font-mono"></strong></p><button class="btn-primary text-sm" onclick="copyGenCode()">${t('admin_copy_code')}</button><span id="copy-ok" class="text-green-600 ml-2 hidden">${t('admin_copied')}</span></div></div>
            <div id="table-section" class="bg-white dark:bg-slate-800 rounded-2xl p-6 overflow-x-auto"><h3 class="text-xl font-bold mb-4">📋 هەموو لیستینگەکان (${listings.length})</h3>
            <table class="admin-table w-full text-sm"><thead><tr><th>ID</th><th>ناونیشان</th><th>پۆلێن</th><th>نرخ</th><th>کۆد</th><th>بەکارهاتوو</th><th>خاوەن</th><th>ژمارە</th><th>🔗 بەستەر</th></tr></thead><tbody>
            ${listings.map(l=>{ const cc=codes.filter(c=>c.target_listing_id===l.id); return `<tr><td>${l.id}</td><td>${l.title?.ku||''}</td><td>${tCat(l.category)}</td><td>${l.base_price}</td><td>${cc.map(c=>c.code_string).join(', ')||'---'}</td><td>${cc.map(c=>c.is_used?'بەڵێ':'نەخێر').join(', ')||'---'}</td><td>${l.hidden_premium_info?.owner_name||'---'}</td><td dir="ltr">${l.hidden_premium_info?.owner_phone||'---'}</td><td><button class="copy-link-btn" onclick="copyListingLink(${l.id})" title="${t('copy_listing_link')}"><svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg></button></td></tr>`; }).join('')}
            </tbody></table></div></div></div>`;
        }
    }

    function scrollToSection(e,id){ e.preventDefault(); document.getElementById(id)?.scrollIntoView({behavior:'smooth'}); }

    function handleAdminLogin(){
        const u=document.getElementById('admin-user')?.value.trim(), p=document.getElementById('admin-pass')?.value.trim();
        if(u===ADMIN_USERNAME && p===ADMIN_PASSWORD){ isAdminLoggedIn=true; sessionStorage.setItem('dozer_admin_v5','true'); renderApp(); }
        else{ document.getElementById('admin-error')?.classList.remove('hidden'); document.getElementById('admin-pass').value=''; }
    }
    function handleAdminLogout(){ isAdminLoggedIn=false; sessionStorage.removeItem('dozer_admin_v5'); navigateTo('/'); }

    function handleAddListing(e){
        e.preventDefault(); const f=new FormData(e.target);
        const listing={ id:nextListingId(), title:{ku:f.get('tku'),ar:f.get('tar'),en:f.get('ten')}, general_description:{ku:f.get('dku'),ar:f.get('dar'),en:f.get('den')}, category:f.get('cat'), main_image_url:f.get('img')||'https://placehold.co/600x400', base_price:f.get('price'), unlock_fee:f.get('fee'), hidden_premium_info:{owner_name:f.get('owner'),owner_phone:f.get('phone'),exact_location:f.get('loc'),admin_notes:f.get('notes')} };
        const code={ code_id:nextCodeId(), code_string:genUniqueCode(), target_listing_id:listing.id, is_used:false };
        const listings=getListings(); listings.push(listing); saveListings(listings);
        const codes=getCodes(); codes.push(code); saveCodes(codes);
        document.getElementById('add-result').classList.remove('hidden');
        document.getElementById('add-msg').textContent=t('admin_listing_saved');
        document.getElementById('add-code').textContent=code.code_string;
        e.target.reset(); renderApp(); showToast('✅ لیستینگ زیادکرا','success');
    }
    function handleGenerateCode(){
        const id=parseInt(document.getElementById('gen-id')?.value);
        if(!id||!getListings().some(l=>l.id===id)){ showToast('ID دروست نییە','error'); return; }
        const code={ code_id:nextCodeId(), code_string:genUniqueCode(), target_listing_id:id, is_used:false };
        getCodes().push(code); saveCodes(getCodes());
        document.getElementById('gen-display').classList.remove('hidden');
        document.getElementById('gen-code').textContent=code.code_string;
        renderApp(); showToast('✅ کۆد دروستکرا','success');
    }
    function copyGenCode(){ const v=document.getElementById('gen-code')?.textContent; if(v) navigator.clipboard.writeText(v).then(()=>{ document.getElementById('copy-ok').classList.remove('hidden'); setTimeout(()=>document.getElementById('copy-ok').classList.add('hidden'),2000); }); }

    // New function to copy listing link from admin table
    function copyListingLink(id) {
        const url = window.location.origin + window.location.pathname + '#/item/' + id;
        navigator.clipboard.writeText(url).then(()=> showToast(t('listing_link_copied'),'success')).catch(()=> showToast('Copy failed','error'));
    }

    // ==================== MODAL ====================
    window._unlockId=null;
    function openUnlockModal(id){ window._unlockId=id; document.getElementById('unlock-modal').style.display='flex'; document.body.style.overflow='hidden'; document.getElementById('activation-code-input').value=''; document.getElementById('modal-error').classList.add('hidden'); }
    function closeModal(){ document.getElementById('unlock-modal').style.display='none'; document.body.style.overflow=''; }
    function handleVerifyCode(){
        const code=document.getElementById('activation-code-input')?.value.trim().toUpperCase();
        const id=window._unlockId;
        if(!code||!id) return;
        const matched=getCodes().find(c=>c.code_string===code && c.target_listing_id===id && !c.is_used);
        if(matched){ matched.is_used=true; saveCodes(getCodes()); sessionStorage.setItem('unlock_'+id,'true'); closeModal(); renderApp(); showToast(t('code_verified'),'success'); }
        else{ document.getElementById('modal-error').classList.remove('hidden'); document.getElementById('activation-code-input').value=''; }
    }

    // ==================== TOAST ====================
    function showToast(msg,type='success'){ const c=document.getElementById('toast-container'); const t=document.createElement('div'); t.className=`toast toast-${type}`; t.textContent=msg; c.appendChild(t); setTimeout(()=>{ t.style.opacity='0'; setTimeout(()=>t.remove(),300); },3000); }

    // ==================== EVENTS ====================
    document.getElementById('lang-switcher').addEventListener('change',function(){ currentLang=this.value; localStorage.setItem('dozer_lang_v5',currentLang); renderApp(); });
    window.addEventListener('hashchange',()=>{ renderApp(); window.scrollTo({top:0}); });
    document.getElementById('unlock-modal').addEventListener('click',function(e){ if(e.target===this) closeModal(); });
    document.getElementById('verify-code-btn').addEventListener('click',handleVerifyCode);
    document.addEventListener('keydown',e=>{ if(e.key==='Escape' && document.getElementById('unlock-modal').style.display==='flex') closeModal(); });

    // Expose all necessary globals
    window.navigateTo=navigateTo; window.openUnlockModal=openUnlockModal; window.closeModal=closeModal;
    window.handleAdminLogin=handleAdminLogin; window.handleAdminLogout=handleAdminLogout;
    window.handleAddListing=handleAddListing; window.handleGenerateCode=handleGenerateCode;
    window.copyGenCode=copyGenCode; window.scrollToSection=scrollToSection;
    window.selectFilterCategory=selectFilterCategory; window.shareListing=shareListing;
    window.toggleFilterDropdown=toggleFilterDropdown; window.toggleDarkMode=toggleDarkMode;
    window.handleVerifyCode=handleVerifyCode; window.handleLogoTap=handleLogoTap;
    window.copyListingLink=copyListingLink;   // for admin table copy button

    // Init
    applyDarkMode(); document.getElementById('lang-switcher').value=currentLang; updateDirection(); renderApp();
})();
</script>
</body>
</html>
